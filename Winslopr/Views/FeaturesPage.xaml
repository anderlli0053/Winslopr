<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Winslopr.Views.FeaturesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winslopr"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="Transparent">

    <Page.Resources>
        <local:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" />
        <local:StatusToBrushConverter x:Key="StatusToBrushConverter" />
    </Page.Resources>

    <!-- PAGE CARD -->
    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid RowDefinitions="Auto,*">

            <!-- Toolbar: profile chip + issues filter -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8"
                        Padding="12,10,12,6" VerticalAlignment="Center">
                <ComboBox x:Name="comboProfiles" x:Uid="ComboProfiles"
                          FontSize="11.5" FontWeight="SemiBold" Height="30"
                          CornerRadius="15" Padding="8,0"
                          Background="{ThemeResource ControlFillColorSecondaryBrush}" />
                <ToggleButton x:Name="chkIssuesOnly" x:Uid="ChkIssuesOnly"
                              CornerRadius="15" Padding="10,4" FontSize="11.5" FontWeight="SemiBold"
                              Background="{ThemeResource ControlFillColorSecondaryBrush}"
                              IsEnabled="False"
                              Checked="chkIssuesOnly_Changed" Unchecked="chkIssuesOnly_Changed" />
            </StackPanel>

            <TreeView Grid.Row="1" x:Name="treeFeatures" SelectionMode="None" Padding="8,0,8,10">
                <TreeView.ItemTemplate>
                    <DataTemplate x:DataType="local:FeatureTreeItem">
                        <TreeViewItem ItemsSource="{x:Bind FilteredChildren}" IsExpanded="True">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <CheckBox IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                          IsEnabled="{x:Bind IsApplicableOnOS}"
                                          MinWidth="0" MinHeight="0" Padding="4,0,0,0" />
                                <Border Width="16" Height="16" CornerRadius="5" VerticalAlignment="Center"
                                        Background="{x:Bind Status, Mode=OneWay, Converter={StaticResource StatusToBrushConverter}}" />
                                <Button Tag="{x:Bind}" Click="ItemMenuButton_Click"
                                        Height="26" Padding="6,2" CornerRadius="9"
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1" VerticalAlignment="Center">
                                    <!-- Fluent Icons = Win11+. Falls back to MDL2 on Win10 -->
                                    <FontIcon Glyph="&#xE712;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" />
                                </Button>
                                <TextBlock Text="{x:Bind Name}"
                                           VerticalAlignment="Center"
                                           FontSize="12.5"
                                           FontFamily="Segoe UI Variable Text"
                                           FontWeight="{x:Bind IsCategory, Converter={StaticResource BoolToFontWeightConverter}}" />
                                <TextBlock Text="{x:Bind ApplicabilityText}" VerticalAlignment="Center"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           FontSize="10.5"
                                           Opacity="0.82" />
                            </StackPanel>
                        </TreeViewItem>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>
    </Border>
</Page>
