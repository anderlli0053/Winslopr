<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Winslopr.Views.InstallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winslopr.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="Transparent">

    <!-- PAGE CARD -->
    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid RowDefinitions="Auto,Auto,*">

            <!-- Toolbar: filters left, action buttons right -->
            <Grid Grid.Row="0" Padding="12,10,12,8" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <ComboBox x:Name="comboCategory"
                              x:Uid="ComboCategory" FontSize="11.5" FontWeight="SemiBold" Height="30"
                              CornerRadius="15" Padding="8,0"
                              Background="{ThemeResource ControlFillColorSecondaryBrush}"
                              SelectionChanged="comboCategory_SelectionChanged" />
                    <ToggleButton x:Name="chkInstalledOnly" x:Uid="ChkInstalledOnly"
                                  CornerRadius="15" Padding="10,4" FontSize="11.5" FontWeight="SemiBold"
                                  Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                  Checked="chkFilter_Changed" Unchecked="chkFilter_Changed" />
                    <ToggleButton x:Name="chkUpgradesOnly" x:Uid="ChkUpgradesOnly"
                                  CornerRadius="15" Padding="10,4" FontSize="11.5" FontWeight="SemiBold"
                                  Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                  Checked="chkFilter_Changed" Unchecked="chkFilter_Changed" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button x:Name="btnInstall"         x:Uid="BtnInstall"         Click="btnInstall_Click"         FontSize="11.5" Padding="10,4" CornerRadius="14" />
                    <Button x:Name="btnUpgradeSelected" x:Uid="BtnUpgradeSelected" Click="btnUpgradeSelected_Click" FontSize="11.5" Padding="10,4" CornerRadius="14" />
                    <Button x:Name="btnUpgradeAll"      x:Uid="BtnUpgradeAll"      Click="btnUpgradeAll_Click"      FontSize="11.5" Padding="10,4" CornerRadius="14" />
                    <Button x:Name="btnUninstall"       x:Uid="BtnUninstall"       Click="btnUninstall_Click"       FontSize="11.5" Padding="10,4" CornerRadius="14" />
                </StackPanel>
            </Grid>

            <!-- Column headers -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="32,2*,3*,90,90"
                  Padding="14,6,14,8"
                  BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                  BorderThickness="0,0,0,1">
                <TextBlock Grid.Column="1" x:Uid="ColAppName"   FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="2" x:Uid="ColPackageId" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="3" x:Uid="ColInstalled"  FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="4" x:Uid="ColUpdate"     FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>

            <!-- App list -->
            <ListView Grid.Row="2" x:Name="listApps" SelectionMode="None" IsItemClickEnabled="True"
                      ItemClick="listApps_ItemClick" Padding="0,0,0,8">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding"   Value="14,0" />
                        <Setter Property="MinHeight" Value="36" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:InstallEntry">
                        <Grid ColumnDefinitions="32,2*,3*,90,90" VerticalAlignment="Center">
                            <CheckBox Grid.Column="0" IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                      MinWidth="0" MinHeight="0" Margin="0" />
                            <TextBlock Grid.Column="1" Text="{x:Bind Name}"
                                       VerticalAlignment="Center" FontSize="11.5"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="{x:Bind WingetId}"
                                       VerticalAlignment="Center" FontSize="10" Opacity="0.6"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="3" Text="{x:Bind InstalledLabel, Mode=OneWay}"
                                       Foreground="{x:Bind InstalledColor, Mode=OneWay}"
                                       VerticalAlignment="Center" FontSize="11" />
                            <TextBlock Grid.Column="4" Text="{x:Bind UpdateLabel, Mode=OneWay}"
                                       Foreground="{x:Bind UpdateColor, Mode=OneWay}"
                                       VerticalAlignment="Center" FontSize="11" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Border>
</Page>
