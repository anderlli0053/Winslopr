<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Winslopr.Views.AppsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winslopr.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="Transparent">

    <!-- PAGE CARD -->
    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid RowDefinitions="Auto,*">

            <!-- Toolbar -->
            <ComboBox x:Name="comboDisplayMode" Grid.Row="0"
                      FontSize="11.5" FontWeight="SemiBold" Height="30"
                      CornerRadius="15" Padding="8,0" Margin="12,10,12,6"
                      Background="{ThemeResource ControlFillColorSecondaryBrush}" />

            <Grid Grid.Row="1">
                <ListView x:Name="listApps" SelectionMode="None" IsItemClickEnabled="True" Padding="8,0,8,10">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:AppItem">
                            <CheckBox IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                      Content="{x:Bind DisplayName}"
                                      HorizontalAlignment="Stretch"
                                      MinWidth="0" FontSize="11.5" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <ProgressRing x:Name="scanSpinner" IsActive="False" Visibility="Collapsed"
                              HorizontalAlignment="Center" VerticalAlignment="Center" Width="40" Height="40" />
            </Grid>
        </Grid>
    </Border>
</Page>
