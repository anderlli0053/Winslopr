<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Winslopr.Views.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ext="using:Winslopr.Tools"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="Transparent">

    <!-- PAGE CARD -->
    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid RowDefinitions="Auto,*">

            <!-- Toolbar: filter left, status right -->
            <Grid Grid.Row="0" Padding="12,10,12,8" ColumnDefinitions="Auto,*,Auto">
                <ComboBox x:Name="comboFilter" Grid.Column="0"
                          x:Uid="ComboFilter" FontSize="11.5" FontWeight="SemiBold" Height="30"
                          CornerRadius="15" Padding="8,0"
                          Background="{ThemeResource ControlFillColorSecondaryBrush}"
                          SelectionChanged="comboFilter_SelectionChanged" />
                <TextBlock x:Name="lblStatus" Grid.Column="2" FontSize="11.5"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
            </Grid>

            <!-- Content: list left, details right -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1.4*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="12,8,8,12">
                    <ListView x:Name="listTools" SelectionMode="Single"
                              SelectionChanged="listTools_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="ext:ToolsDefinition">
                                <TextBlock Text="{x:Bind Title}" FontSize="12.5" FontFamily="Segoe UI Variable Text" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- DETAIL PANE -->
                <Border Grid.Column="1" Margin="8,8,12,12"
                        CornerRadius="6"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid Margin="14">
                    <StackPanel x:Name="panelPlaceholder"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Spacing="8" Opacity="0.5">
                        <FontIcon Glyph="&#xE7C5;" FontSize="36" HorizontalAlignment="Center" />
                        <TextBlock x:Uid="Tools_SelectHint" FontSize="13" HorizontalAlignment="Center" />
                    </StackPanel>

                    <ScrollViewer x:Name="scrollDetails" VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <StackPanel x:Name="panelDetails" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Name="lblIcon" FontSize="22" VerticalAlignment="Center" />
                                <TextBlock x:Name="lblTitle" FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center" TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock x:Name="lblDescription" FontSize="12" TextWrapping="Wrap"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                            <InfoBar x:Name="infoHelp" Severity="Warning" IsOpen="False"
                                     IsClosable="False" Margin="0,2,0,2">
                                <InfoBar.ActionButton>
                                    <Button x:Name="btnShowHelp" Click="btnShowHelp_Click"
                                            Content="Show help" FontSize="11" />
                                </InfoBar.ActionButton>
                            </InfoBar>
                            <ComboBox x:Name="comboOptions" HorizontalAlignment="Stretch"
                                      Visibility="Collapsed" x:Uid="ComboOptions" />
                            <TextBox x:Name="textInput" HorizontalAlignment="Stretch"
                                     Visibility="Collapsed" x:Uid="TextInput" />
                            <HyperlinkButton x:Name="linkPoweredBy" Visibility="Collapsed"
                                             FontSize="11" Padding="0" Click="linkPoweredBy_Click" />
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button x:Name="btnRun" x:Uid="BtnRun" Click="btnRun_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Visibility="Collapsed" FontSize="11" Padding="12,4" />
                                <Button x:Name="btnUninstall" x:Uid="BtnToolUninstall" Click="btnUninstall_Click"
                                        Visibility="Collapsed" FontSize="11" Padding="12,4" />
                                <Button x:Name="btnOpenFolder" Content="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                        Click="btnOpenFolder_Click" FontSize="11" Padding="8,4"
                                        x:Uid="BtnOpenFolder" />
                            </StackPanel>
                            <ProgressRing x:Name="progressRing" IsActive="False"
                                          Width="24" Height="24" HorizontalAlignment="Left" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Page>
